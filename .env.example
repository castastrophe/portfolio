# Netlify Blobs — required for local dev to read content data
# Get these from Netlify: Site settings > General > Site details (ID)
# and User settings > Personal access tokens (token)
NETLIFY_SITE_ID=
NETLIFY_TOKEN=

# Allow the site id to be visible because it's not a secret value
SECRETS_SCAN_OMIT_KEYS=NETLIFY_SITE_ID

# Default dev environment settings
NODE_ENV=development
WATCH_MODE=true
NETLIFY_BUILD_HOOK_URL=

GITHUB_PERSONAL_ACCESS_TOKEN=
