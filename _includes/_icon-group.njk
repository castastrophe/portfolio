{% css %}
.icon-group {
    display: var(--icon-group--Display, inline-flex);
    row-gap: var(--theme--content--space);
    column-gap: var(--theme--content--space);

    a {
        inline-size: 1.2em;
        font-size: 1.2em;
        block-size: fit-content;
        display: inline-grid;
        place-items: center;

        &:where(:not(:hover, :focus, :focus-visible)) {
            color: var(--theme--text--Color--subtle);
        }
    }
}
{% endcss %}

<div class="icon-group"{% if icons.length < 2 %} style="align-self: start"{% endif %}{% if slot %} slot="{{ slot }}"{% endif %}>
    {% for icon in icons | default(candidate.socials) %}
    <a href="//{{ icon.url }}" rel="{{ icon.rel }}" aria-label="{{ icon.label}} ">
        <span class="{{ icon.classes }}"></span>
    </a>
    {% endfor %}
</div>
