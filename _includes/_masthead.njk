<div class="masthead container">
    <div class="branding">
        <a class="branding-image" href="/" title="Return to the home page">
            <img src="../img/logo.svg" alt="Allons-y Consulting logo, a colorful illustration of a coffee mug">
        </a>
    </div>
    <div class="content">
        <h1>{{ site.title }}</h1>
        <div class="navigation">
            {{ collections.all | eleventyNavigation | eleventyNavigationToHtml | safe }}
    
            {% set icons = site.socials | featured %}
            {% include "_icon-group.njk" %}
        </div>
    </div>
</div>

{% css %}
.masthead {
    display: flex;
    flex-flow: row wrap;
    justify-content: center;
    align-items: center;
    column-gap: calc(var(--spacing--horizontal) * 4);
    row-gap: var(--spacing--vertical);
    box-sizing: border-box;
    inline-size: min(1200px, 100%);
    max-inline-size: calc(100vw - (var(--spacing--horizontal) * 1.2));
    min-block-size: calc(clamp(180px, 18vw, 200px) + var(--spacing--vertical) * 4);
    margin-inline: auto;
    padding-block: calc(var(--spacing--vertical) * 2);
    padding-inline: calc(var(--spacing--horizontal) * .6);

    .branding {
        --border-radius: 50%;

        .branding-image {
            display: flex;
            aspect-ratio: 1 / 1;
            inline-size: clamp(180px, 18vw, 200px);
            block-size: auto;

            img {
                box-sizing: border-box;
                border-radius: var(--border-radius);
                border: 2px solid var(--theme--ui--Color--subtle);
                inline-size: 100%;
                block-size: 100%;
            }

            &:is(:hover, :focus, :focus-visible) img {
                border-color: var(--theme--ui--Color);
            }
        }
    }

    .content {
        flex-grow: 1;
        display: flex;
        
        flex-flow: column nowrap;
        max-inline-size: 100%;

        > h1,
        > h2 {
            margin-block-end: var(--spacing--vertical);
            line-height: 1.1;
        }

        > h1 {
            font-size: calc(2.4em + 1vw);
            font-weight: 800;

            @media screen and (width <= 460px) {
                font-size: calc(2.1em + 1vw);
            }
        }

        > h2 {
            font-size: calc(1em + 1vw);
            font-weight: 100;
        }
    }
}

.navigation {
    border-block-start: 2px solid var(--theme--ui--Color);
    padding-block-start: 0.8em;

    display: inline-flex;
    flex-flow: row wrap;
    justify-content: space-between;
    row-gap: var(--spacing--vertical);
    column-gap: var(--spacing--horizontal);
}

.navigation {
    display: inline-flex;
    flex-flow: row wrap;
    flex-grow: 1;

    ul {
        display: inline-flex;
        gap: 20px;
        list-style-type: none;
        margin: 0;
        padding: 0;
    }

    [aria-page="current"] a {
        color: inherit;
        text-decoration: underline;
    }

    a:focus-visible {
        outline: 2px solid var(--theme--ui--Color--active);
        outline-offset: var(--outline-offset, 4px);
        border-radius: calc(var(--border-radius) / 2);
    }
}

@media screen and (width <= 460px) {
    .navigation + .icon-group {
        display: none;
    }
}
{% endcss %}
