---
layout: foundation
customSheets:
  - home
---

{% include "../../pages/background.svg" %}

{% if masthead %}
    {% include "../_masthead.njk" %}
{% endif %}

<main>{{ content | safe }}</main>

<a-band id="contact" full thin>
    <div slot="footer">
        {% set icons = candidate.socials %}
        {% include "../_icon-group.njk" %}
    </div>
    <a slot="footer" href="{{ site.funding[0].url }}" {% if site.funding[0].ratio %}style="--aspect-ratio: {{ site.funding[0].ratio }};"{% endif %} title="{{ site.funding[0].label }}">
        {% if site.funding[0].img %}<img src="{{ site.funding[0].img }}" alt="{{ site.funding[0].label }}">{% else %}<span>{{ site.funding[0].label }}</span>{% endif %}
    </a>
</a-band>

{% js %}
    import '/js/components/a-band.js';
    import '/js/components/a-card.js';
    import '/js/components/a-note.js';
    import '/js/components/tag-group.js';
{% endjs %}
