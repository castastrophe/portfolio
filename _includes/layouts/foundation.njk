{% set isPost = collections.posts | getCollectionItem %}

<!DOCTYPE html>
<html lang="{{ site.language }}">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, minimum-scale=1.0, initial-scale=1.0, user-scalable=yes">

    <meta name="theme-color" content="{{ site.themeColor }}">
    <meta name="color-scheme" content="light dark">
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <meta name="keywords" content="{{ keywords or site.keywords }}">
    <meta name="author" content="{{ site.author }}">
    <meta name="generator" content="{{ eleventy.generator }}">

    {% if indexed != false %}
    <meta name="robots" content="index, follow">
    <meta name="googlebot" content="index, follow">
    <meta name="bingbot" content="index, follow">
    <meta name="yandexbot" content="index, follow">
    {% endif %}

    <!-- Open Graph data -->
    <meta property="og:title" content="{{ title or site.title }}">
    <meta property="og:url" content="{{ site.url }}">
    <meta property="og:description" content="{{ description or site.description }}">
    <meta property="og:site_name" content="{{ site.title }}">

    {% if isPost %}
    <meta property="og:type" content="article">
    <meta property="article:author" content="{{ site.author }}">
    <meta property="article:published_time" content="{{ date | toISOString }}">
    <meta property="article:modified_time" content="{{ date | toISOString }}">
    {% else %}
    <meta property="og:type" content="website">
    {% endif %}

    <link rel="icon" href="/favicon.ico" sizes="32×32">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/favicon.svg">

    {% if fonts %}
    {{ fonts | safe }}
    {% endif %}

    {% for customSheet in customSheets %}
    <link rel="stylesheet" href="{{ '/css/' + customSheet + '.css' | url }}">
    {% endfor %}

    {% if prism %}
    <link rel="stylesheet" href="{{ '/css/prism.css' | url }}"/>
    <link rel="stylesheet" href="{{ '/css/prism-one-light.css' | url }}"/>
    <link rel="stylesheet" href="{{ '/css/prism-one-dark.css' | url }}" media="(prefers-color-scheme: dark)"/>
    {% endif %}

    <style>{% getBundle "css" %}</style>

    <script src="https://kit.fontawesome.com/42e99b4632.js" crossorigin="anonymous"></script>
</head>

<body {% if prism %}class="line-numbers"{% endif %}>
    {{ content | safe }}

    <footer>
        {% if prism %}
        <script type="module" src="{{ '/js/prism.js' | url }}"></script>
        <script type="module" src="{{ '/js/prism-toolbar.js' | url }}"></script>
        <script type="module" src="{{ '/js/prism-copy-to-clipboard.js' | url }}"></script>
        <script type="module" src="{{ '/js/prism-line-numbers.js' | url }}"></script>
        <script type="module" src="{{ '/js/prism-normalize-whitespace.js' | url }}"></script>
        {% endif %}

        <script type="module" src="{% getBundleFileUrl 'js' %}"></script>
    </footer>
</body>

</html>
