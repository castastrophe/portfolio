{% set isPost = collections.posts | getCollectionItem %}

<!DOCTYPE html>
<html lang="{{ site.language }}">

<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, minimum-scale=1.0, initial-scale=1.0, user-scalable=yes">

    <meta name="theme-color" content="{{ site.themeColor }}">
    <meta name="color-scheme" content="light dark">
    <title>{{ title || site.title }}</title>
    <meta name="description" content="{{ description || site.description }}">
    <meta name="keywords" content="{{ keywords || site.keywords }}">
    <meta name="author" content="{{ site.author }}">

    <link rel="icon" href="/img/favicon.ico" sizes="32×32">
    <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/img/allonsy-logo.png">

    <!-- Open Graph data -->
    <meta property="og:title" content="{{ title || site.title }}">
    {% if not isPost %}<meta property="og:type" content="website">{% endif %}
    <meta property="og:url" content="{{ site.url }}">
    <meta property="og:description" content="{{ description || site.description }}">
    <meta property="og:site_name" content="{{ site.title }}">

    <meta name="generator" content="{{ eleventy.generator }}">

    {% if isPost %}
        <meta property="og:type" content="article">
        <meta property="article:author" content="{{ site.author }}">
        <meta property="article:published_time" content="{{ date | toISOString }}">
        <meta property="article:modified_time" content="{{ date | toISOString }}">
    {% endif %}

    {% if resume %}
        {% if candidate.tagline %}<meta name="description" content="{{ candidate.tagline | clean }}">{% endif %}
        {% if candidate.name %}<meta name="author" content="{{ candidate.name }}">{% endif %}
        {% if candidate.skills %}<meta name="keywords" content="{{ candidate.skills | join(', ') }}">{% endif %}
        <meta name="robots" content="index, follow">
        <meta name="googlebot" content="index, follow">
        <meta name="bingbot" content="index, follow">
        <meta name="yandexbot" content="index, follow">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400..700&family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="/css/resume.css">
        <script src="https://kit.fontawesome.com/42e99b4632.js" crossorigin="anonymous"></script>
    {% endif %}

    <style>{% getBundle "css" %}</style>

    <link rel="stylesheet" href="/css/prism.css"/>
    <link rel="stylesheet" href="/css/prism-one-light.css"/>
    <link rel="stylesheet" href="/css/prism-one-dark.css" media="(prefers-color-scheme: dark)"/>

    <link rel="stylesheet" href="/css/home.css"/>
    <script src="https://kit.fontawesome.com/42e99b4632.js" crossorigin="anonymous"></script>
</head>

<body>
    {{ content }}

    <footer>
        <script type="module" src="{% getBundleFileUrl 'js' %}"></script>
        <script type="module" src="{{ '/js/prism.js' | url }}"></script>
        <script type="module" src="{{ '/js/home.js' | url }}"></script>

        {% for component in collections.components %}
            <script type="module" src="{{ '/js' + component.inputPath | replace('/pages', '') | url }}"></script>
        {% endfor %}
    </footer>
</body>

</html>
