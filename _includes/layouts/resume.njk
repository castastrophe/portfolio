---
indexed: false
customSheets:
  - theme
  - animation
  - core
  - resume
eleventyComputed:
  title: "{{ candidate.name }} | Resume"
  description: "{{ resume.tagline }}"
  keywords: "{{ resume.skills | join(',', 'items') }}"
  author: "{{ candidate.name }}"
---

{% extends "layouts/foundation.njk" %}

{% block header %}
<div id="header-sticky" class="sticky" hidden aria-hidden="true">
  <div class="container">
    <div class="photo"></div>
    <div>
      <h1 class="candidate-name">
        <span>{{ candidate.name | first }}</span>
        <span>{{ candidate.name | last }}</span>
      </h1>
      {% if resume.tagline %}
      <p class="subtitle">{{ resume.tagline }}</p>
      {% endif %}
    </div>
  </div>
</div>

<a href="#main-content" class="skip-link cta-button">Skip to content</a>
{% endblock %}

{% block content %}
<!-- I know, a table layout?! However, it's the only way to ensure that the header appears at the top of every page when printed. -->
<table>
  <thead>
    <tr>
      <th>
        <header id="header" role="banner">
          <div class="photo">
            {% set photoAlt = "A photo of " + candidate.name + ", a red-haired woman with a smile" %}
            {% image "img/cassondra-roberts.png", photoAlt %}
          </div>
          <div>
            <h1 class="candidate-name">
              <span>{{ candidate.name | first }}</span>
              <br/>
              <span>{{ candidate.name | last }}</span>
            </h1>
            {% if resume.tagline %}
            <p class="subtitle">{{ resume.tagline }}</p>
            {% endif %}
          </div>
        </header>
      </th>
    </tr>
  </thead>
  <tbody id="main-content" aria-label="Main content" tabindex="-1" role="main">{{ content | safe }}</tbody>
</table>
{% endblock %}

{% block footer %}
<button type="button" class="print" aria-label="Print to PDF">
  <span class="fa-solid fa-file-pdf" aria-hidden="true"></span>
  <span class="print-button-text">Export</span>
</button>
{% endblock %}

{% js %}
document.addEventListener("DOMContentLoaded", () => {
  const header = document.getElementById("header");
  const fixedHeader = document.getElementById("header-sticky");
  let fixedHeight;

  function checkStickyHeader() {
    if(window.scrollY > header.offsetHeight) {
      fixedHeader.removeAttribute('hidden');
      if (!fixedHeight || fixedHeight !== fixedHeader.offsetHeight) {
        fixedHeight = fixedHeader.offsetHeight;
        document.body.setAttribute("data-sticky-height", fixedHeight);
        document.body.style.setProperty("scroll-padding-block-start", fixedHeight + "px");
      }
    } else {
      fixedHeader.setAttribute('hidden', '');
    }
  }

  if (header && fixedHeader) {
    checkStickyHeader();
  }

  // Wire up print button
  const printButton = document.querySelector('button.print');
  printButton?.addEventListener('click', () => window.print());

  // Show print button after scrolling stops
  let scrollTimeout;
  let hasScrolled = false;

  function showButton() {
    printButton.classList.add('visible');
  }

  function hideButton() {
    printButton.classList.remove('visible');
  }

  window.addEventListener('scroll', () => {
    hasScrolled = true;

    if (header && fixedHeader) checkStickyHeader();

    hideButton();
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(showButton, 800);
  }, { passive: true });

  // Show button on initial load after a delay
  setTimeout(showButton, 1500);
});
{% endjs %}
