---
layout: base
tags:
    - listing
customScripts:
    - listing
---

{% include "masthead.njk" %}

{% set allTags = collections[key] | allTags %}
{% set listingUrl = page.url %}

<main id="main-content" aria-label="Main content" tabindex="-1">
    <a-band class="listing" thick>
        <div slot="header">
            <h2 class="title highlight">{{ title }}</h2>
            {% if description %}<p class="header-summary">{{ description }}</p>{% endif %}
            {{ content | safe }}
        </div>

        {% if allTags.length > 0 %}
        <a-container>
            <nav class="tag-filters" aria-label="Filter by tag">
                <a href="{{ listingUrl }}" class="tag-filter clear" data-tag="">show all</a>
                {% for tag in allTags %}
                <a href="{{ listingUrl }}?tag={{ tag | urlencode }}" class="tag-filter" data-tag="{{ tag }}">{{ tag }}</a>
                {% endfor %}
            </nav>
        </a-container>
        {% endif %}

        {% for item in collections[key] | reverse %}
        {% set itemPage = item.page %}
        {% set data = item.data %}
        {% set itemTags = data.tags | contentTags %}
        {% if data.title %}
            <a-card bordered data-tags="{{ itemTags | join(',') }}">
                <div slot="header">
                    {% if itemPage.date %}<p class="date">{{ itemPage.date | long }}</p>{% endif %}
                    <h3 class="headline accent">{% if itemPage.url %}<a href="{{ itemPage.url }}">{% endif %}{{ data.title }}{% if itemPage.url %}</a>{% endif %}</h3>
                </div>
                {% if data.description %}<p class="content">{{ data.description }}</p>{% endif %}
                {% if itemTags.length > 0 %}<tag-group tags="{{ itemTags | join(',') }}" filters url="{{ listingUrl }}" labeled slot="footer"></tag-group>{% endif %}
            </a-card>
        {% endif %}
        {% endfor %}
    </a-band>

    {% include "cta-band.njk" %}
</main>

{% css %}
.tag-filters {
    display: flex;
    flex-flow: row wrap;
    gap: .5em;
    margin: 0;
    padding: 0;
    list-style: none;
}

.clear {
    margin-inline-end: 1em;
}

.tag-filter {
    display: inline-block;
    padding: .2em .6em;
    border-radius: var(--theme--BorderRadius);
    background-color: var(--theme--surface--color);
    color: contrast-color(var(--theme--surface--color));
    border: var(--theme--BorderWidth--thin) solid var(--theme--ui--color);
    text-decoration: none;
    font-size: .9em;
    font-weight: var(--theme--FontWeight--light);
    cursor: pointer;
    transition: background-color 150ms ease;
    text-transform: lowercase;
}

.tag-filter:hover {
    background-color: var(--theme--ui--color--hover);
    color: contrast-color(var(--theme--ui--color--hover));
}

.tag-filter[aria-current="true"] {
    background-color: var(--theme--ui--color);
    color: contrast-color(var(--theme--ui--color));
}
{% endcss %}
