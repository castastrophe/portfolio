{
  "private": true,
  "name": "allons-y",
  "version": "1.0.0",
  "description": "Personal portfolio site",
  "license": "MIT",
  "author": "Cassondra Roberts <castastrophe@users.noreply.github.com> (https://allons-y.llc)",
  "homepage": "https://allons-y.llc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/castastrophe/personal-site.git"
  },
  "bugs": {
    "url": "https://github.com/castastrophe/personal-site/issues"
  },
  "type": "module",
  "main": "public/index.html",
  "imports": {
    "#filters": "./utilities/filters/index.js",
    "#transforms": "./utilities/transforms/index.js"
  },
  "scripts": {
    "ci": "cross-env ELEVENTY_ENV=production yarn build",
    "postinstall": "husky && envoy",
    "build": "eleventy",
    "check:links:internal": "NODE_OPTIONS='--no-deprecation' node utilities/tasks/check-links.js --internal",
    "check:links:external": "NODE_OPTIONS='--no-deprecation' node utilities/tasks/check-links.js --external",
    "check:links": "NODE_OPTIONS='--no-deprecation' node utilities/tasks/check-links.js",
    "clean": "rimraf public",
    "start": "eleventy --serve",
    "dev": "netlify dev",
    "test": "NODE_OPTIONS='--no-deprecation' vitest run",
    "test:watch": "NODE_OPTIONS='--no-deprecation' vitest watch"
  },
  "workspaces": [
    ".github/actions/*"
  ],
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-navigation": "^1.0.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@allons-y/envoy": "^1.1.0",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@netlify/api": "^14.0.18",
    "@netlify/blobs": "^10.7.4",
    "@netlify/functions": "^5.2.0",
    "@types/broken-link-checker": "^0.7.3",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.11.3",
    "babelify": "^10.0.0",
    "broken-link-checker": "^0.7.8",
    "browserify": "^17.0.1",
    "colors": "^1.4.0",
    "cross-env": "^10.1.0",
    "cssnano": "^7.1.7",
    "dotenv": "^17.4.2",
    "eleventy-plugin-toc": "^1.1.5",
    "eslint": "^10.2.1",
    "esmify": "^2.1.1",
    "gravatar": "^1.8.2",
    "happy-dom": "^20.9.0",
    "html-minifier": "^4.0.0",
    "husky": "^9.1.7",
    "hyperlink": "^5.0.4",
    "js-yaml": "^4.1.1",
    "lint-staged": "^16.4.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-anchor-sections": "^1.0.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "netlify-cli": "^24.11.3",
    "netlify-plugin-11ty": "^1.5.0",
    "npm-run-all2": "^8.0.0",
    "postcss": "^8.5.10",
    "postcss-load-config": "^6.0.1",
    "postcss-preset-env": "^11.2.1",
    "postcss-reporter": "^7.1.0",
    "posthtml": "^0.16.7",
    "prettier": "^3.8.3",
    "prettier-package-json": "^2.8.0",
    "prism-themes": "^1.9.0",
    "rimraf": "^6.1.3",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-use-logical": "^2.1.3",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "portfolio",
    "consulting",
    "front-end",
    "design systems",
    "web components",
    "architecture",
    "development",
    "blog"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.14.1",
  "browserify": {
    "transform": [
      [
        "babelify",
        {
          "presets": [
            "@babel/preset-env"
          ],
          "sourceMaps": true,
          "compact": true,
          "minified": true
        }
      ]
    ]
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
