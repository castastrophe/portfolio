{% css %}
#consulting {
    .bio {
        border-radius: var(--border-radius);
        padding-inline: var(--theme--content--space);
        background-color: color-mix(in srgb, var(--theme--surface--color) 80%, transparent);
        margin-block-start: var(--theme--content--space);

        &:not(:first-of-type) {
            margin-block-start: calc(var(--theme--content--space) * 2);
        }

        .container {
            --card--Width: 250px;

            border-block-start: 1px solid var(--theme--ui--Color--subtle);
            padding-block-start: var(--theme--container--space);
            display: flex;
            flex-flow: row wrap;
            gap: var(--theme--content--space);
            align-items: start;

            a-card {
                text-align: center;

                [slot="footer"] {
                    font-size: .8em;
                    border-block-start: 1px solid color-mix(in srgb, var(--theme--ui--Color) 20%, transparent);
                    padding-block-start: var(--theme--content--space);
                    inline-size: 80cqi;
                    margin-inline: auto;
                }
            }

            .content {
                flex-grow: 1;
                inline-size: calc(100% - var(--card--Width) - var(--theme--content--space) * 2);
                min-inline-size: min(50ch, 100%);
            }
        }
    }

    .projects,
    .presentations {
        --card--Width: 365px;

        inline-size: 100%;

        [layout="row"] {
            font-size: .8em;
            display: flex;
            flex-flow: row wrap;
            gap: 1.25em;
            justify-content: start;
        }
    }
}
{% endcss %}
