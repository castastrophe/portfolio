---
layout: base
date: Last Modified
priority: "1.0"
eleventyNavigation:
  key: Home
  order: 1
---

{% block masthead %}
    {% include "masthead.njk" %}
{% endblock %}

{% block content %}
<main id="main-content" aria-label="Main content" tabindex="-1">
    <a-band id="about">
        <a-card bordered featured class="accent--blue">
            <div class="content">
                <p class="headline-summary"><strong>We create custom web apps & design systems that help teams ship faster with confidence.</strong></p>
                <p>If your product experience is inconsistent, your handoff is brittle, or your front-end foundation is slowing delivery, we help you turn that friction into a scalable system: clear standards, accessible components, and a codebase your team can build on. With expertise from Adobe, Red Hat, and the W3C CSS Working Group, plus dedicated project leadership, we guide the work from strategy through implementation.</p>
            </div>
            <p slot="footer">
                <a class="cta-link" href="mailto:{{ site.contact.email }}?subject=Discovery%20call%20request">Book discovery call</a>
            </p>
            <p slot="footer">
                <a class="cta-link" href="{{ '/about/' | url }}">See recent work</a>
            </p>
        </a-card>
    </a-band>

    {% if services.length > 0 %}
    <a-band id="services" thick class="accent--yellow">
        <h2 class="title highlight" slot="header">Services</h2>
        {% for service in services %}
        <a-card bordered overflow grow featured>
            <h2 class="title" slot="header" id="{{ service.category | url }}-{{ loop.index }}">{{ service.category }}</h2>
            <div class="content">
                <p>{{ service.description }}</p>
            </div>
        </a-card>
        {% endfor %}
        <a-card bordered featured overflow class="contact-card accent--reset" slot="aside">
            <h2 class="title" slot="header">Let's talk</h2>
            {% set messageLabel = "What would you like to build or improve?" %}
            {% include "contact-form.njk" %}
        </a-card>
    </a-band>
    {% endif %}

    <a-band id="posts" thin>
        <h2 class="title highlight" slot="header"><a href="{{ '/posts/' | url }}" title="View all posts">Posts</a></h2>
        {% for article in collections.posts | featured | reverse %}
        <a-card bordered style="--card--header--Gap--vertical: 0;">
            <h3 class="headline accent" slot="header"><a href="{{ article.url | validateURL }}">{{ article.data.title }}</a></h3>
            <p class="date" slot="header">{{ article.data.date | long }}</p>
            {% if article.data.description %}<p class="content" style="margin-block: .5em;">{{ article.data.description }}</p>{% endif %}
            {% if article.data.tags.length > 0 %}<tag-group tags="{{ article.data.tags | join(',') }}" labeled url="{{ '/posts/' | url }}" filters slot="footer"></tag-group>{% endif %}
        </a-card>
        {% endfor %}
    </a-band>

    <!-- Recorded talks -->
    <a-band id="presentations" thick class="accent--blue">
        <h2 class="title highlight" slot="header"><a href="{{ '/presentations/' | url }}">Presentations</a></h2>
        <a-card slot="header" full>
            <p class="header-summary">Presentations or interviews I've given at various events, conferences, podcasts, and streams.</p>
            <p class="header-summary">Connecting with individuals and organizations to share my knowledge and experiences is one of my favorite parts of my job. I'd love to hear about your event or podcast to see how we can work together. <a href="mailto:{{ site.contact.email }}">Email me</a> to discuss your needs.</p>
        </a-card>

        {% for presentation in presentations | featured %}
            {% include "video-card.njk" %}
        {% endfor %}
    </a-band>
</main>
{% endblock %}
