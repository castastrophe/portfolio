---
layout: base
masthead: true
eleventyNavigation:
  key: Writing
  order: 3
---

<a-band full id="posts" padding="double" grid full>
    <h2 class="title" slot="header">Posts</h2>
    {% for article in collections.posts | reverse %}
        <a-card bordered>
            <div slot="header">
                <h3 class="headline accent"><a href="{{ article.url }}">{{ article.data.title }}</a></h3>
                <p class="date">{{ article.data.date | postDate }}</p>
            </div>
            <p>{{ article.data.description }}</p>
            {% if article.data.tags.length > 0 %}<tag-group tags="{{ article.data.tags | join(',') }}" labeled slot="footer"></tag-group>{% endif %}
        </a-card>
    {% endfor %}
</a-band>

<a-band padding="half" id="cta">
    <a-note></a-note>
</a-band>

{% css %}
#posts {
    --spacing--vertical: 2em;

    &:is([full]) {
        --columns: 2;
    }

    @media screen and (width <= 992px) {
        --columns: 1;
    }
}
{% endcss %}
